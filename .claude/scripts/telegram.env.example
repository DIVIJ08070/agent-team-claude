# Copy this file to telegram.env (same directory) and fill in the values.
# telegram.env is gitignored — never commit real tokens.
#
# Setup steps:
#   1. In Telegram, talk to @BotFather → /newbot → repeat 5× to create:
#        manager, designer, developer, qa, scribe bots.
#      BotFather gives you a token like  123456789:AAF-abc...  for each.
#   2. Create a Telegram group and add all 5 bots to it.
#      (For each bot, also send /setprivacy → Disable to BotFather if you
#       want the bots to read group messages; for posting-only it's not needed.)
#   3. Get the group chat id: add @RawDataBot (or @getidsbot) to the group,
#      copy the "chat" → "id" value (negative number like -1001234567890),
#      then remove that helper bot.
#   4. Fill everything in below. Leave any token empty to silently disable
#      that agent's notifications — the team works fine without Telegram.

TG_MANAGER_TOKEN=""
TG_DESIGNER_TOKEN=""
TG_DEVELOPER_TOKEN=""
TG_QA_TOKEN=""
TG_SCRIBE_TOKEN=""

# The group chat id all bots post into (starts with -100 for supergroups)
TG_CHAT_ID=""
